# Copy this file to .env.local and add your API keys

# OpenAI API key - Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# PhilEx Shipping API Configuration
# Contact PhilEx to get your API credentials
PHILEX_API_URL=https://api.philex.ph
PHILEX_EMAIL=your-philex-email@example.com
PHILEX_PASSWORD=your-philex-password

# Nanucell Pickup Address (for PhilEx shipping)
NANUCELL_PHONE=09XXXXXXXXX
NANUCELL_ADDRESS=Your complete pickup address
NANUCELL_REGION=luzon
NANUCELL_PROVINCE=Metro Manila
NANUCELL_MUNICIPALITY=Makati
NANUCELL_BARANGAY=Poblacion
